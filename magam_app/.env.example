# Supabase (클린아이덱스와 동일 프로젝트)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 공유 링크 도메인 (웹 /p/[slug])
MAGAM_SHARE_BASE_URL=https://cleanidex.co.kr

# 카카오 OAuth — 웹(localhost) 전용. APK 빌드 시 이 값은 무시됩니다.
# Supabase Redirect URLs 에 io.supabase.magamapp://login-callback/ 도 등록하세요.
MAGAM_OAUTH_REDIRECT_URL=http://localhost:54222/
# 프로덕션 PWA: https://cleanidex.co.kr/magam/app/ (코드에서 자동 감지, Supabase에만 등록하면 됨)
