# Supabase (클린아이덱스와 동일 프로젝트)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 공유 링크 도메인 (웹 /p/[slug])
MAGAM_SHARE_BASE_URL=https://cleanidex.co.kr

# (선택) 카카오 OAuth 후 돌아올 URL — Supabase Redirect URLs 와 동일해야 함
# Flutter web 예: http://localhost:54321/
# MAGAM_OAUTH_REDIRECT_URL=http://localhost:54321/
