# Supabase
# https://supabase.com/dashboard 프로젝트 설정에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 나라장터(공공데이터포털) 입찰공고정보서비스
# https://www.data.go.kr/data/15129394 → 데이터 요청 → 조달청_나라장터 입찰공고정보서비스 → 일반 인증키(Encoding) 복사 후 아래에 붙여넣기
DATA_GO_KR_SERVICE_KEY=

# 나라장터 낙찰정보서비스(ScsbidInfo, 용역) — 입찰공고 키와 별도 활용신청 시 Encoding 키
# tender_award_raw 수집: /api/cron/fetch-scsbid-award-raw
DATA_GO_KR_SCSBID_SERVICE_KEY=
# 낙찰 API 개찰일시(inqryDiv=3) 조회 슬라이딩 구간(분). 미설정 시 250(약 4시간 10분). 최대 20160(14일)
# SCSBID_AWARD_CRON_LOOKBACK_MINUTES=
# SCSBID_AWARD_INGEST_MAX_ROWS_PER_RUN=2500

# 고용24 워크넷 채용정보 Open API — /api/cron/sync-worknet-jobs (12시간마다 권장)
# WORKNET_API_KEY=
# 키워드당 최대 수집 행 수 (기본 500)
# WORKNET_INGEST_MAX_ROWS=500
# 청소 매칭 키워드 JSON 배열 (미설정 시: 청소,용역,위생,방역,시설관리 등)
# WORKNET_CLEANING_KEYWORDS=["청소","용역","위생","방역","시설관리"]

# 크론 호출 시 인증 (선택) — POST /api/cron/naver-trend-report, /api/cron/job-wage-daily-report 등 x-cron-secret 헤더
CRON_SECRET=

# 쿠팡 파트너스 Open API — 파트너스 콘솔 Tools → 파트너스 API
# 슬롯별 상품 캐시 갱신: POST /api/cron/refresh-coupang-ads (x-cron-secret)
COUPANG_PARTNERS_ACCESS_KEY=
COUPANG_PARTNERS_SECRET_KEY=

# 네이버 데이터랩 통합 검색어 트렌드 API (마케팅 리포트 / 입주수요 demand_keyword_daily)
# https://developers.naver.com/apps — 데이터랩(검색어트렌드) 사용 신청
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 입주수요 검색 지표 cron: /api/cron/ingest-demand-keywords (KST 03:30, naver-trend 다음)
# DEMAND_DATALAB_DAYS_BACK=60
# DEMAND_DATALAB_MONTHS_BACK=12
# 입주수요 허브 — 포장이사 검색량·검색지수 원본 열(개발용). 1=표시 0=숨김. 미설정 시 development=표시, production=숨김
# NEXT_PUBLIC_DEMAND_SHOW_PACKING_SEARCH_BREAKDOWN=1
# 네이버 검색광고 API — searchad.naver.com [도구] → SA API 사용 관리
# 액세스 라이선스 / 비밀키 / 고객 ID (데이터랩 NAVER_CLIENT_* 와 별도)
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=
# 별칭(선택): NAVER_SEARCHAD_ACCESS_LICENSE=  ← API_KEY 와 동일 값

# 국토부 RTMS (아파트 매매/전월세) — /api/cron/ingest-demand-rtms-seoul
# 공공데이터포털에서 국토교통부_아파트매매 실거래자료 / 전월세 실거래자료 활용신청 후 Encoding 키 사용
MOLIT_RTMS_SERVICE_KEY=
# 서비스별 분리 키를 쓰는 경우 (권장): 아래 2개 사용
MOLIT_RTMS_TRADE_SERVICE_KEY=
MOLIT_RTMS_RENT_SERVICE_KEY=
# 조회 개월 수 (기본 2 = 증분·MoM). 최초 백필은 관리자 「백필 (36개월)」 또는 36 설정
DEMAND_RTMS_MONTHS_BACK=2

# 부트페이 (구독 결제) — https://admin.bootpay.co.kr/setting/developer
NEXT_PUBLIC_BOOTPAY_APPLICATION_ID=
BOOTPAY_PRIVATE_KEY=
BOOTPAY_MODE=production

# 구독 갱신 cron용 (process-subscriptions에서 DB 업데이트 시 필요)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlycmhxZGN2ZmJqZG1qcWZzc25yIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjY4OTQ5OSwiZXhwIjoyMDg4MjY1NDk5fQ.-6RNaEx2MdQ429sAbbmGcEuIGMvl68SkZVXmlNuI2xc


