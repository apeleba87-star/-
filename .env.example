# Supabase
# https://supabase.com/dashboard 프로젝트 설정에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 나라장터(공공데이터포털) 입찰공고정보서비스
# https://www.data.go.kr/data/15129394 → 데이터 요청 → 조달청_나라장터 입찰공고정보서비스 → 일반 인증키(Encoding) 복사 후 아래에 붙여넣기
DATA_GO_KR_SERVICE_KEY=

# 크론 호출 시 인증 (선택) — POST /api/cron/naver-trend-report, /api/cron/job-wage-daily-report 등 x-cron-secret 헤더
CRON_SECRET=

# 네이버 데이터랩 통합 검색어 트렌드 API (마케팅 리포트 cron / 관리자 수동 갱신)
# https://developers.naver.com/apps — 데이터랩(검색어트렌드) 사용 신청
NAVER_CLIENT_ID=dvMK5RWxZ4Ymfn9eb6cB
NAVER_CLIENT_SECRET=xvc31tpglJ

# 부트페이 (구독 결제) — https://admin.bootpay.co.kr/setting/developer
NEXT_PUBLIC_BOOTPAY_APPLICATION_ID=
BOOTPAY_PRIVATE_KEY=
BOOTPAY_MODE=production

# 구독 갱신 cron용 (process-subscriptions에서 DB 업데이트 시 필요)
SUPABASE_SERVICE_ROLE_KEY=
