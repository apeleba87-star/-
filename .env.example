# Supabase
# https://supabase.com/dashboard 프로젝트 설정에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 나라장터(공공데이터포털) 입찰공고정보서비스
# https://www.data.go.kr/data/15129394/openapi.do 활용신청 후 인증키(Encoding) 복사
DATA_GO_KR_SERVICE_KEY=

# 크론 호출 시 인증 (선택)
CRON_SECRET=

# 부트페이 (구독 결제) — https://admin.bootpay.co.kr/setting/developer
NEXT_PUBLIC_BOOTPAY_APPLICATION_ID=
BOOTPAY_PRIVATE_KEY=
BOOTPAY_MODE=production

# 구독 갱신 cron용 (process-subscriptions에서 DB 업데이트 시 필요)
SUPABASE_SERVICE_ROLE_KEY=
